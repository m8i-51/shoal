{
  "name": "@m8i-51/shoal",
  "version": "0.1.14",
  "type": "module",
  "description": "Multi-agent web exploration framework — finds bugs, UX issues, and missing features by running AI agents against your app",
  "repository": {
    "type": "git",
    "url": "https://github.com/m8i-51/shoal"
  },
  "bin": {
    "shoal": "./bin/shoal.js"
  },
  "files": [
    "bin/",
    "framework/",
    "targets/",
    "server/",
    "web/dist/",
    "run.ts",
    "triage-only.ts",
    ".env.example"
  ],
  "scripts": {
    "prepublishOnly": "npm run build:web",
    "start": "tsx run.ts",
    "triage": "tsx triage-only.ts",
    "serve": "tsx server/index.ts",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch --no-cache server/index.ts",
    "dev:web": "vite web",
    "build:web": "vite build web",
    "auth:codex": "tsx scripts/auth-codex.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.1",
    "@anthropic-ai/sdk": "^0.91.1",
    "@clack/prompts": "^1.3.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "openai": "^6.33.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.6",
    "concurrently": "^10.0.3",
    "i18next": "^26.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.14.1",
    "typescript": "^5",
    "vite": "^6.4.2",
    "vitest": "^4.1.5"
  }
}
